# ============================================
# VARIABLES DE ENTORNO - PRODUCCIÓN
# ============================================
# Copiar este archivo a .env en producción
# y completar los valores según corresponda

# ============================================
# BASE DE DATOS (OBLIGATORIO)
# ============================================

# PostgreSQL - Obtener de Railway/Supabase/Neon
# Formato: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://..."

# Para Prisma (sin pooler, para migraciones)
DATABASE_DIRECT_URL="postgresql://..."


# ============================================
# REDIS (REQUERIDO PARA WORKERS/BULLMQ)
# ============================================

# Redis - Obtener de Railway/Upstash
# Formato: redis://username:password@host:port
REDIS_URL="redis://..."


# ============================================
# MEILISEARCH (OPCIONAL - BÚSQUEDA AVANZADA)
# ============================================

MEILISEARCH_URL="https://your-meilisearch-instance.meilisearch.com"
MEILISEARCH_MASTER_KEY="your-master-key"


# ============================================
# AUTHENTICATION - CLERK (OBLIGATORIO)
# ============================================

# Obtener de Clerk Dashboard > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."

# Webhook secret - Obtener de Clerk Dashboard > Webhooks
CLERK_WEBHOOK_SECRET="whsec_..."

# URLs de redirect
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/register"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"


# ============================================
# IA - OPENAI (OPCIONAL)
# ============================================

# Obtener de https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."


# ============================================
# IA - ANTHROPIC (OPCIONAL)
# ============================================

# Obtener de https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."


# ============================================
# ALMACENAMIENTO - CLOUDFLARE R2 (OPCIONAL)
# ============================================

# Obtener de Cloudflare Dashboard > R2 > Manage API Tokens
CLOUDFLARE_R2_ACCOUNT_ID="your-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-access-key"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-secret-key"
CLOUDFLARE_R2_BUCKET_NAME="vt-files"


# ============================================
# EMAIL - RESEND (OPCIONAL)
# ============================================

# Obtener de https://resend.com/api-keys
RESEND_API_KEY="re_..."


# ============================================
# APIS EXTERNAS (OPCIONAL)
# ============================================

# Lens.org - Patentes
# Obtener de https://www.lens.org/
LENS_API_KEY=""

# Semantic Scholar - Artículos académicos
# Obtener de https://api.semanticscholar.org/api/
SEMANTIC_SCHOLAR_API_KEY=""

# NCBI/PubMed
# Obtener de https://www.ncbi.nlm.nih.gov/settings/
PUBMED_API_KEY=""


# ============================================
# APP CONFIG (OBLIGATORIO)
# ============================================

# URL pública de la app - IMPORTANTE: cambiar en producción
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Entorno
NODE_ENV="production"


# ============================================
# OTRAS VARIABLES (OPCIONAL)
# ============================================

# Sentry - Error tracking
# Obtener de https://sentry.io/settings/
SENTRY_DSN=""

# ============================================
# NOTAS IMPORTANTES:
# ============================================
#
# 1. Las variables marcadas como OBLIGATORIO deben estar
#    configuradas para que la app funcione.
#
# 2. DATABASE_URL es la más importante - sin ella,
#    la app no podrá hacer queries a la base de datos.
#
# 3. Para obtener DATABASE_URL:
#    - Railway: Deploy > PostgreSQL > Connection String
#    - Supabase: Settings > Database > Connection String
#    - Neon: Connection Details > Connection String
#
# 4. Para obtener REDIS_URL:
#    - Railway: Deploy > Redis > Connection String
#    - Upstash: Redis Database > Connect > Connection
#
# 5. Las variables de Clerk deben ser las de PRODUCCIÓN
#    (pk_live_xxx, sk_live_xxx), NO las de desarrollo.
#
# 6. En Vercel: agregar estas variables en Settings > Environment Variables
#    Para Railway: agregar en Variables de la configuración del servicio
#
# ============================================